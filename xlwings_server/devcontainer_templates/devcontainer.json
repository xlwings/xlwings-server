// For format details, see https://aka.ms/devcontainer.json.
// For config options, see https://containers.dev/.
// To share Git ssh keys with the container on macOS, run on the LOCAL terminal:
//   ssh-add ~/.ssh/id_ed25519
{
    "name": "xlwings Server",
    "image": "mcr.microsoft.com/devcontainers/python:3-3.14-bookworm",
    // Persist the uv cache across container rebuilds for faster `uv sync`.
    // On local Docker this gives real reuse across rebuilds. On Codespaces the
    // cache and workspace are on different filesystems regardless, so
    // UV_LINK_MODE=copy is required there (and harmless locally).
    "mounts": [
        "source=xlwings-server-uv-cache,target=/home/vscode/.cache/uv,type=volume"
    ],
    "containerEnv": {
        "UV_LINK_MODE": "copy",
        "UV_COMPILE_BYTECODE": "1"
    },
    // Forward FastAPI dev server.
    "forwardPorts": [8000],
    // Fix ownership on the named volume, then install uv and sync dependencies.
    "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.cache/uv && pip install --user --upgrade uv && uv sync",
    // pre-commit and git need this when the workspace is bind-mounted.
    "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "samuelcolvin.jinjahtml",
                "tamasfe.even-better-toml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    }
                }
            }
        }
    },
    "remoteUser": "vscode"
}
